<mxfile host="app.diagrams.net" modified="2026-05-12T00:00:00.000Z" agent="Codex native-drawio" version="24.7.17" type="device">
  <diagram id="F4" name="F4">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="640" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="F4 · 潜在优化路线图：算法、内核、系统三层" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#1f2328;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="375.40" y="10.80" width="349.20" height="37.20" as="geometry"/></mxCell><mxCell id="c3" value="把后续优化拆成可验证假设：先问瓶颈在哪里，再问哪种改法能移除或隐藏成本。" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=center;verticalAlign=middle;fontSize=16;fontStyle=0;fontColor=#59636e;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="379.72" y="49.20" width="340.56" height="24.80" as="geometry"/></mxCell><mxCell id="c4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf8e7;strokeColor=#57a451;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="55.00" y="105.00" width="990.00" height="132.00" as="geometry"/></mxCell><mxCell id="c5" value="A. 算法层：减少推理/投影成本" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#27313d;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="90.00" y="117.05" width="188.24" height="29.45" as="geometry"/></mxCell><mxCell id="c6" value="① FP8/NVFP4 低精度残差　② Sinkhorn 早停/自适应迭代　③ Newton-Schulz 并行正交化　④ KromHC / mHC-lite　⑤ 推理 early-stop" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=left;verticalAlign=middle;fontSize=16;fontStyle=0;fontColor=#4b5563;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="90.00" y="157.20" width="869.20" height="24.80" as="geometry"/></mxCell><mxCell id="c7" value="核心问题：n² 投影与 n 倍残差带宽是否能在推理端继续摊薄？" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=left;verticalAlign=middle;fontSize=14;fontStyle=0;fontColor=#5b6570;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="90.00" y="192.30" width="261.04" height="24.00" as="geometry"/></mxCell><mxCell id="c8" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff1ef;strokeColor=#b85450;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="55.00" y="265.00" width="990.00" height="132.00" as="geometry"/></mxCell><mxCell id="c9" value="B. 内核层：减少 launch、HBM 与 backward 成本" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#27313d;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="90.00" y="277.05" width="379.76" height="29.45" as="geometry"/></mxCell><mxCell id="c10" value="⑥ 拆开 pre_big_fuse 提升 WGMMA/warp-specialization　⑦ implicit-diff Sinkhorn　⑧ TMA multicast expand　⑨ CUDA Graph 捕获" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=left;verticalAlign=middle;fontSize=16;fontStyle=0;fontColor=#4b5563;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="90.00" y="317.20" width="1003.60" height="24.80" as="geometry"/></mxCell><mxCell id="c11" value="最值得优先验证：⑦ 用隐式微分替代显式 Sinkhorn backward，可能同时降显存和重算。" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=left;verticalAlign=middle;fontSize=14;fontStyle=0;fontColor=#5b6570;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="90.00" y="352.30" width="402.16" height="24.00" as="geometry"/></mxCell><mxCell id="c12" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4ff;strokeColor=#5680c2;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="55.00" y="425.00" width="990.00" height="132.00" as="geometry"/></mxCell><mxCell id="c13" value="C. 系统层：训练并行与大 n 扩展" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#27313d;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="90.00" y="437.05" width="209.52" height="29.45" as="geometry"/></mxCell><mxCell id="c14" value="⑩ 残差流 FP8 持久化　⑪ 动态 expansion rate　⑫ HBM/PP stage 对齐　⑬ hierarchical mHC" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=left;verticalAlign=middle;fontSize=16;fontStyle=0;fontColor=#4b5563;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="90.00" y="477.20" width="645.20" height="24.80" as="geometry"/></mxCell><mxCell id="c15" value="边界条件：这些优化需要和 pipeline stage、activation recompute、通信重叠一起评估。" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=left;verticalAlign=middle;fontSize=14;fontStyle=0;fontColor=#5b6570;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="90.00" y="512.30" width="472.72" height="24.00" as="geometry"/></mxCell><mxCell id="c16" value="读法：每一项都应写成 bottleneck → mechanism → tradeoff → ablation，而不是“技巧清单”。" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=center;verticalAlign=middle;fontSize=16;fontStyle=0;fontColor=#59636e;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="245.32" y="585.20" width="609.36" height="24.80" as="geometry"/></mxCell></root>
    </mxGraphModel>
  </diagram>
</mxfile>
