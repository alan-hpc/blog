        <mxCell id="title" value="F4 · mHC 后续优化横向树状图" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1f2328;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="410" y="8" width="300" height="30" as="geometry"/></mxCell><mxCell id="root" value="&lt;b&gt;后续优化&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;12 项 ablation&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;按层级排期&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#fff7ed;strokeColor=#d18616;strokeWidth=1.6;fontColor=#24292f;fontSize=13;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="28" y="210" width="150" height="78" as="geometry"/></mxCell><mxCell id="catA" value="&lt;b&gt;算法层&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;投影 / 数值 / 近似&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#eef7ee;strokeColor=#5fa55f;strokeWidth=1.6;fontColor=#24292f;fontSize=14;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="232" y="52" width="150" height="68" as="geometry"/></mxCell><mxCell id="e_root_catA" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7b8794;strokeWidth=1.4;endArrow=block;endFill=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="178" y="249" as="sourcePoint"/><mxPoint x="232" y="86" as="targetPoint"/></mxGeometry></mxCell><mxCell id="catK" value="&lt;b&gt;内核层&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;融合 / 并行 / launch&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1.6;fontColor=#24292f;fontSize=14;fontFamily=Helvetica;align=center