ometry relative="1" as="geometry"><mxPoint x="420" y="374" as="sourcePoint"/><mxPoint x="420" y="444" as="targetPoint"/></mxGeometry></mxCell><mxCell id="e_catS_trunk" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=1.4;endArrow=block;endFill=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="382" y="402" as="sourcePoint"/><mxPoint x="420" y="402" as="targetPoint"/></mxGeometry></mxCell><mxCell id="e_S_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=1.4;endArrow=block;endFill=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="420" y="374" as="sourcePoint"/><mxPoint x="452" y="374" as="targetPoint"/></mxGeometry></mxCell><mxCell id="e_S_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=1.4;endArrow=block;endFill=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="420" y="409" as="sourcePoint"/><mxPoint x="452" y="409" as="targetPoint"/></mxGeometry></mxCell><mxCell id="e_S_3_link" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6b7280;strokeWidth=1.4;endArrow=block;endFill=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="420" y="444" as="sourcePoint"/><mxPoint x="683" y="431" as="targetPoint"/></mxGeometry></mxCell><mxCell id="a1" value="&lt;b&gt;① Hpre/Hpost 低精度&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;推理量化 · Sinkhorn 保 fp32&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#8fc48f;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="452" y="28" width="205" height="42" as="geometry"/></mxCell><mxCell id="a2" value="&lt;b&gt;② Sinkhorn 早停&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;20 轮 → 3-5 轮 · 推理短线&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#8fc48f;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="452" y="78" width="205" height="42" as="geometry"/></mxCell><mxCell id="a3" value="&lt;b&gt;③ Newton-Schulz&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;并行替代 Sinkhorn · 长线&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#8fc48f;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="452" y="128" width="205" height="42" as="geometry"/></mxCell><mxCell id="a4" value="&lt;b&gt;④ KromHC / mHC-lite&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;大 n 近似投影 · 推理&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#8fc48f;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="683" y="28" width="205" height="42" as="geometry"/></mxCell><mxCell id="a5" value="&lt;b&gt;⑤ 残差流 FP8&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;训练激活减半 · 显存优先&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#8fc48f;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="683" y="128" width="205" height="42" as="geometry"/></mxCell><mxCell id="k6" value="&lt;b&gt;⑥ 拆 pre_big_fuse&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;WGMMA / WS 回来&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#d79a92;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="452" y="190" width="205" height="42" as="geometry"/></mxCell><mxCell id="k7" value="&lt;b&gt;⑦ implicit-diff bwd&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;Sinkhorn 反向 5-10×&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#d79a92;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="452" y="240" width="205" height="42" as="geometry"/></mxCell><mxCell id="k8" value="&lt;b&gt;⑧ TMA multicast&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;expand 写入加速&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#d79a92;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="452" y="290" width="205" height="42" as="geometry"/></mxCell><mxCell id="k9" value="&lt;b&gt;⑨ CUDA Graph&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;低 batch launch 合并&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#d79a92;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="683" y="240" width="205" height="42" as="geometry"/></mxCell><mxCell id="s10" value="&lt;b&gt;⑩ 动态 expansion rate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;浅层小 n · 深层大 n&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#8da8e8;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="452" y="360" width="205" height="42" as="geometry"/></mxCell><mxCell id="s11" value="&lt;b&gt;⑪ Hres 解码缓存&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;复用历史 token mixing&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#8da8e8;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="452" y="410" width="205" height="42" as="geometry"/></mxCell><mxCell id="s12" value="&lt;b&gt;⑫ Hierarchical mHC&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;n≥16 分组 Sinkhorn&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#8da8e8;strokeWidth=1.6;fontColor=#24292f;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=0;spacing=6;" vertex="1" parent="1"><mxGeometry x="683" y="410" width="205" height="42" as="geometry"/></mxCell><mxCell id="tagInfer" value="&lt;b&gt;推理短线&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;①②④⑨&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#8fc48f;strokeWidth=1.6;fontColor=#2d6a2d;fontSize=12;fontFamily=Helvetica;align=center;verticalAlign=middle;fontStyle=1;spacing=6;" vertex="1" parent="1"><mxGeometry x="925" y="72" width="155" height="44" as="geometry"/></mxCell><mxCell id="tagTrain" value="&lt;b&gt;训练短线&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px;color:#667085&quot;&gt;⑤⑦⑧&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#ffffff;strokeColor=#d79a92;strokeWidth=1.6;fontColor=#8a2f2a;font