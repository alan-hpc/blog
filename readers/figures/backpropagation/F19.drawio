=middle;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;fontFamily=sans-serif;fontSize=13;fontColor=#24292f;spacing=6;" vertex="1" parent="1"><mxGeometry x="760" y="145" width="112" height="58" as="geometry" /></mxCell><mxCell id="add2" value="+" style="ellipse;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#ffffff;strokeColor=#b85450;strokeWidth=2;fontSize=18;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1"><mxGeometry x="901" y="159" width="30" height="30" as="geometry" /></mxCell><mxCell id="x2" value="&lt;i&gt;X&lt;sub&gt;2&lt;/sub&gt;&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fillColor=#eef7ff;strokeColor=#4a6fd3;strokeWidth=2;fontFamily=sans-serif;fontSize=13;fontColor=#24292f;spacing=6;" vertex="1" parent="1"><mxGeometry x="955" y="150" width="42" height="48" as="geometry" /></mxCell><mxCell id="e1" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="x" target="ln1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e2" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="ln1" target="attn"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e3" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="attn" target="add1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e4" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="add1" target="x1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e5" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="x1" target="ln2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e6" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="ln2" target="mlp"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e7" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="mlp" target="add2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e8" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="add2" target="x2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="skip1" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;dashed=1;" edge="1" parent="1" source="x" target="add1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="skip2" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#24292f;strokeWidth=2;dashed=1;" edge="1" parent="1" source="x1" target="add2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="b1" value="&lt;b&gt;加法节点 1 的反向&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#a33ea1&quot;&gt;&lt;i&gt;Δ&lt;sub&gt;X&lt;/sub&gt; = Δ&lt;sub&gt;X1&lt;/sub&gt; + B&lt;sub&gt;attn&lt;/sub&gt;(Δ&lt;sub&gt;X1&lt;/sub&gt;)&lt;/i&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#57606a&quot; style=&quot;font-size:11px&quot;&gt;跳连项直接回到 X，主支穿过 W&lt;sub&gt;o&lt;/sub&gt;/MHA/LN 后再加回来。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fillColor=#fbf0fb;strokeColor=#a33ea1;strokeWidth=2;fontFamily=sans-serif;fontSize=13;fontColor=#24292f;spacing=6;" vertex="1" parent="1"><mxGeometry x="90" y="305" width="390" height="78" as="geometry" /></mxCell><mxCell id="b2" value="&lt;b&gt;加法节点 2 的反向&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#a33ea1&quot;&gt;&lt;i&gt;Δ&lt;sub&gt;X1&lt;/sub&gt; = Δ&lt;sub&gt;X2&lt;/sub&gt; + B&lt;sub&gt;mlp&lt;/sub&gt;(Δ&lt;sub&gt;X2&lt;/sub&gt;)&lt;/i&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#57606a&quot; style=&quot;font-size:11px&quot;&gt;同一个规则在 MLP 残差子层上再执行一次。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fillColor=#fbf0fb;strokeColor=#a33ea1;strokeWidth=2;fontFamily=sans-serif;fontSize=13;fontColor=#24292f;spacing=6;" vertex="1" parent="1"><mxGeometry x="520" y="305" width="390" height="78" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>
