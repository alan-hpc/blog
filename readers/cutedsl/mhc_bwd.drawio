<mxfile host="app.diagrams.net"><diagram name="mHC 反向全流程"><mxGraphModel dx="1200" dy="800" grid="1" math="1" page="1" pageWidth="1240" pageHeight="700" background="#ffffff"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="n11" value="&lt;b&gt;∂L/∂x_l （三路累加）&lt;/b&gt;&lt;br&gt;$$\partial L/\partial x_l = \mathrm{res}+\mathrm{pre}+\mathrm{pred}$$&lt;br&gt;&lt;font color=&#x27;#666&#x27; style=&#x27;font-size:10px&#x27;&gt;T × n × C&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="440" y="40" width="280" height="70" as="geometry"/></mxCell><mxCell id="n12" value="&lt;b&gt;① Residual path 反向&lt;/b&gt;&lt;br&gt;$$x_{l,\mathrm{grad}}\mathrel{+}=\sum_r H^{res}_{t,r,s}\,\delta_{t,r,c}$$&lt;br&gt;$$H^{res}_{\mathrm{grad},t,r,s}=\sum_c \delta_{t,r,c}\,x_{l,t,s,c}$$&lt;br&gt;&lt;font color=&#x27;#666&#x27; style=&#x27;font-size:10px&#x27;&gt;per-token n×n 转置矩阵乘（残差高速路）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="20" y="180" width="360" height="130" as="geometry"/></mxCell><mxCell id="n13" value="&lt;b&gt;② Pre path 反向&lt;/b&gt;&lt;br&gt;$$u_{\mathrm{grad}} \leftarrow J_F^{\top} v_{\mathrm{grad}}\ (\mathrm{Layer}\,F)$$&lt;br&gt;$$x_{l,\mathrm{grad}}\mathrel{+}= H^{pre}_{t,s}\,u_{\mathrm{grad},t,c}$$&lt;br&gt;$$H^{pre}_{\mathrm{grad},t,s}=\sum_c u_{\mathrm{grad}}\,x_{l,t,s,c}$$" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="410" y="180" width="360" height="130" as="geometry"/></mxCell><mxCell id="n14" value="&lt;b&gt;③ 预测路 / pre-norm-fn  ★CuteDSL kernel&lt;/b&gt;&lt;br&gt;$$\mathrm{Linear}\,\varphi:\ \bar x_{\mathrm{grad}} = z_{\mathrm{grad}} W_\varphi^{\top}$$&lt;br&gt;$$W_{\varphi,\mathrm{grad}} = \bar x^{\top} z_{\mathrm{grad}}$$&lt;br&gt;$$\mathrm{RMSNorm}:\ x_{l,\mathrm{grad}}\mathrel{+}= r(\bar x_{\mathrm{grad}}-\tfrac{c}{G}\bar x)$$&lt;br&gt;$$r=\mathrm{RMS}(x_l)^{-1},\ c=\langle \bar x_{\mathrm{grad}},\bar x\rangle$$" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#fde7e9;strokeColor=#d6342c;" vertex="1" parent="1"><mxGeometry x="800" y="170" width="380" height="170" as="geometry"/></mxCell><mxCell id="n15" value="&lt;b&gt;∂L/∂x_{l+1} = δ_{l+1}&lt;/b&gt;&lt;br&gt;$$\delta_{l+1}\quad (T\times n\times C)$$" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="470" y="410" width="240" height="70" as="geometry"/></mxCell><mxCell id="n16" value="&lt;b&gt;x_l 的梯度 = 三条路径之和&lt;/b&gt;&lt;br&gt;$$\partial L/\partial x_l = \underbrace{\sum_r H^{res}_{t,r,s}\delta_{t,r,c}}_{\mathrm{res}} + \underbrace{H^{pre}_{t,s}u_{\mathrm{grad}}}_{\mathrm{pre}} + \underbrace{(\mathrm{RMSNorm}\circ\mathrm{Linear})^{\top}}_{\mathrm{pred}}$$&lt;br&gt;&lt;font color=&#x27;#666&#x27; style=&#x27;font-size:10px&#x27;&gt;红框 = pre-norm-fn（RMSNorm + Linear），本文 CuteDSL kernel 负责的部分（168 µs，1.93× TileLang）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;spacing=8;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="20" y="540" width="1160" height="90" as="geometry"/></mxCell><mxCell id="n17" value="" style="endArrow=classic;html=1;rounded=1;strokeColor=#555555;strokeWidth=1.6;fontSize=10;fontColor=#666;" edge="1" parent="1" source="n12" target="n11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n18" value="" style="endArrow=classic;html=1;rounded=1;strokeColor=#555555;strokeWidth=1.6;fontSize=10;fontColor=#666;" edge="1" parent="1" source="n13" target="n11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n19" value="三路求和" style="endArrow=classic;html=1;rounded=1;strokeColor=#555555;strokeWidth=1.6;fontSize=10;fontColor=#666;" edge="1" parent="1" source="n14" target="n11"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n20" value="δ" style="endArrow=classic;html=1;rounded=1;strokeColor=#555555;strokeWidth=1.6;dashed=1;fontSize=10;fontColor=#666;" edge="1" parent="1" source="n15" target="n12"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n21" value="δ 拷贝" style="endArrow=classic;html=1;rounded=1;strokeColor=#555555;strokeWidth=1.6;fontSize=10;fontColor=#666;" edge="1" parent="1" source="n15" target="n13"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n22" value="δ" style="endArrow=classic;html=1;rounded=1;strokeColor=#555555;strokeWidth=1.6;dashed=1;fontSize=10;fontColor=#666;" edge="1" parent="1" source="n15" target="n14"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="n23" value="残差高速路 (Hresᵀ)" style="endArrow=classic;html=1;rounded=1;strokeColor=#d6342c;strokeWidth=1.6;fontSize=10;fontColor=#666;" edge="1" parent="1" source="n15" target="n12"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>