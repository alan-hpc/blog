        <mxCell id="s1" value="&lt;b&gt;① 聚合 split-K&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:13px;color:#5b6570&quot;&gt;从 (16, T, 24) fp32 中&lt;br&gt;aggregate 得 H 原料 + sq-sum&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;strokeWidth=2;align=center;verticalAlign=middle;fontSize=16;fontColor=#111827;fontFamily=Helvetica;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="74" width="210" height="72" as="geometry"/>
