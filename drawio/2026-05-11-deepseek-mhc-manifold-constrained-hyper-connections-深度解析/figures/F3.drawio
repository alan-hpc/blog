        <mxCell id="title" value="F3 · pre_big_fuse_kernel 内部 5-阶段融合（96 线程 · 2 stage · 单 kernel 完成）" style="text;html=1;strokeColor=none;fillColor=none;whiteSpace=wrap;rounded=0;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1a1714;fontFamily=Helvetica;" vertex="1" parent="1">
