        <mxCell id="s2" value="&lt;b&gt;② RMSNorm + α/β&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:13px;color:#5b6570&quot;&gt;rsqrt(sq_sum/h+ε_rms)&lt;br&gt;乘 mhc_scale + mhc_base&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;strokeWidth=2;align=center;verticalAlign=middle;fontSize=16;fontColor=#111827;fontFamily=Helvetica;spacing=8;" vertex="1" parent="1">
