<mxfile host="app.diagrams.net" agent="Codex native-drawio">
  <diagram id="F28" name="F28">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="F28 · Transformer backward 推导查漏表" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontFamily=Helvetica;fontColor=#1f2328;" vertex="1" parent="1"><mxGeometry x="40" y="24" width="900" height="36" as="geometry" /></mxCell>
        <mxCell id="c1" value="1. 完整梯度&lt;br&gt;&lt;font style=&quot;font-size: 13px&quot;&gt;SGD needs ∇θL, not one derivative&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4ff;strokeColor=#5680c2;strokeWidth=2;fontSize=15;fontFamily=Helvetica;fontColor=#27313d;" vertex="1" parent="1"><mxGeometry x="60" y="95" width="260" height="78" as="geometry" /></mxCell>
        <mxCell id="c2" value="2. 两遍算法&lt;br&gt;&lt;font style=&quot;font-size: 13px&quot;&gt;forward saves local slopes; backward carries Δ&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4ff;strokeColor=#5680c2;strokeWidth=2;fontSize=15;fontFamily=Helvetica;fontColor=#27313d;" vertex="1" parent="1"><mxGeometry x="360" y="95" width="260" height="78" as="geometry" /></mxCell>
        <mxCell id="c3" value="3. 路径求和&lt;br&gt;&lt;font style=&quot;font-size: 13px&quot;&gt;shared value accumulates all downstream paths&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4ff;strokeColor=#5680c2;strokeWidth=2;fontSize=15;fontFamily=Helvetica;fontColor=#27313d;" vertex="1" parent="1"><mxGeometry x="660" y="95" width="260" height="78" as="geometry" /></mxCell>
        <mxCell id="c4" value="4. Attention&lt;br&gt;&lt;font style=&quot;font-size: 13px&quot;&gt;ΔY → ΔV / ΔP → ΔS → ΔQ, ΔK&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf8ee;strokeColor=#4ea96b;strokeWidth=2;fontSize=15;fontFamily=Helvetica;fontColor=#27313d;" vertex="1" parent="1"><mxGeometry x="60" y="225" width="260" height="78" as="geometry" /></mxCell>
        <mxCell id="c5" value="5. LayerNorm&lt;br&gt;&lt;font style=&quot;font-size: 13px&quot;&gt;row-local projection; no batch mixing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf8ee;strokeColor=#4ea96b;strokeWidth=2;fontSize=15;fontFamily=Helvetica;fontColor=#27313d;" vertex="1" parent="1"><mxGeometry x="360" y="225" width="260" height="78" as="geometry" /></mxCell>
        <mxCell id="c6" value="6. LoRA&lt;br&gt;&lt;font style=&quot;font-size: 13px&quot;&gt;freeze W0; update D and U only&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf8ee;strokeColor=#4ea96b;strokeWidth=2;fontSize=15;fontFamily=Helvetica;fontColor=#27313d;" vertex="1" parent="1"><mxGeometry x="660" y="225" width="260" height="78" as="geometry" /></mxCell>
        <mxCell id="c7" value="7. Residual add&lt;br&gt;&lt;font style=&quot;font-size: 13px&quot;&gt;copy gradient to skip and branch; merge by addition&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4dc;strokeColor=#d9901a;strokeWidth=2;fontSize=15;fontFamily=Helvetica;fontColor=#3b2c12;" vertex="1" parent="1"><mxGeometry x="210" y="355" width="260" height="78" as="geometry" /></mxCell>
        <mxCell id="c8" value="8. Audit habit&lt;br&gt;&lt;font style=&quot;font-size: 13px&quot;&gt;write dA first, then collect each variable coefficient&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f0;strokeColor=#d66b6b;strokeWidth=2;fontSize=15;fontFamily=Helvetica;fontColor=#27313d;" vertex="1" parent="1"><mxGeometry x="510" y="355" width="260" height="78" as="geometry" /></mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#59636e;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="c1" target="c2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#59636e;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="c2" target="c3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#59636e;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="c4" target="c5"><mxGeometry relative="1" as="geometry" /></mxCell>
