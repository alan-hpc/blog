<mxfile host="app.diagrams.net" modified="2026-05-04T14:30:00.000Z" agent="Codex" version="24.7.17" type="device"><diagram id="F1" name="F1"><mxGraphModel dx="1000" dy="410" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="410" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="阅读路线：从普通 BP 到 Transformer 逐层反传" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=sans-serif;fontSize=24;fontColor=#24292f;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="150" y="22" width="700" height="34" as="geometry" /></mxCell><mxCell id="subtitle" value="先统一 L、θ、Δ 记号，再把每层都读成局部 VJP 与梯度累加" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=sans-serif;fontSize=13;fontColor=#57606a;fontStyle=0;" vertex="1" parent="1"><mxGeometry x="185" y="54" width="630" height="24" as="geometry" /></mxCell><mxCell id="b1" value="&lt;b&gt;SGD 目标&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot; color=&quot;#57606a&quot;&gt;需要整条&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a33ea1&quot;&gt;&lt;i&gt;∇&lt;sub&gt;θ&lt;/sub&gt;L&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fillColor=#eef7ff;strokeColor=#4a6fd3;strokeWidth=2.2;fontFamily=sans-serif;fontSize=14;fontColor=#24292f;spacing=8;" vertex="1" parent="1"><mxGeometry x="70" y="126" width="145" height="96" as="geometry" /></mxCell><mxCell id="b2" value="&lt;b&gt;BP 神经元&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot; color=&quot;#57606a&quot;&gt;局部斜率&lt;br&gt;乘全局误差&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a33ea1&quot;&gt;&lt;i&gt;a&lt;sub&gt;i&lt;/sub&gt;Δ&lt;sub&gt;z&lt;/sub&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2.2;fontFamily=sans-serif;fontSize=14;fontColor=#24292f;spacing=8;" vertex="1" parent="1"><mxGeometry x="245" y="126" width="145" height="96" as="geometry" /></mxCell><mxCell id="b3" value="&lt;b&gt;计算图&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot; color=&quot;#57606a&quot;&gt;分支回流&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a33ea1&quot;&gt;&lt;i&gt;Σ&lt;sub&gt;paths&lt;/sub&gt; Δ·∂&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fillColor=#fff8e7;strokeColor=#e0b300;strokeWidth=2.2;fontFamily=sans-serif;fontSize=14;fontColor=#24292f;spacing=8;" vertex="1" parent="1"><mxGeometry x="420" y="126" width="145" height="96" as="geometry" /></mxCell><mxCell id="b4" value="&lt;b&gt;微分模板&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot; color=&quot;#57606a&quot;&gt;整理微分&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a33ea1&quot;&gt;&lt;i&gt;Δ&lt;sub&gt;A&lt;/sub&gt; : dA&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fillColor=#fbf0fb;strokeColor=#a33ea1;strokeWidth=2.2;fontFamily=sans-serif;fontSize=14;fontColor=#24292f;spacing=8;" vertex="1" parent="1"><mxGeometry x="595" y="126" width="145" height="96" as="geometry" /></mxCell><mxCell id="b5" value="&lt;b&gt;Transformer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot; color=&quot;#57606a&quot;&gt;Q/K/V&lt;br&gt;LN / LoRA&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a33ea1&quot;&gt;&lt;i&gt;Δ&lt;sub&gt;X&lt;/sub&gt;, ∂L/∂W&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2.2;fontFamily=sans-serif;fontSize=14;fontColor=#24292f;spacing=8;" vertex="1" parent="1"><mxGeometry x="770" y="126" width="145" height="96" as="geometry" /></mxCell><mxCell id="e12" style="endArrow=block;html=1;rounded=0;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="b1" target="b2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e23" style="endArrow=block;html=1;rounded=0;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="b2" target="b3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e34" style="endArrow=block;html=1;rounded=0;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="b3" target="b4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e45" style="endArrow=block;html=1;rounded=0;strokeColor=#24292f;strokeWidth=2;" edge="1" parent="1" source="b4" target="b5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="bottom" value="&lt;b&gt;读每一层时固定四个问题&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#a33ea1&quot;&gt;&lt;b&gt;前向对象 → 保存值 → 输入 Δ → 输出 Δ&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot; color=&quot;#57606a&quot;&gt;从标量边梯度到 Transformer 矩阵反传，变的是对象形状，不变的是局部链式法则和路径累加。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fillColor=#f6f8fa;strokeColor=#d0d7de;strokeWidth=1.5;fontFamily=sans-serif;fontSize=15;fontColor=#24292f;spacing=10;" vertex="1" parent="1"><mxGeometry x="95" y="282" width="810" height="74" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>
