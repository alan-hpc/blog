<mxfile host="app.diagrams.net" modified="2026-05-05T00:00:00.000Z" agent="Codex" version="24.7.17" type="device"><diagram id="F1-native" name="F1"><mxGraphModel dx="1000" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="500" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="&lt;b&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;Mega MoE FFN dataflow: keep Combine as an explicit boundary&lt;/font&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="110" y="20" width="780" height="30" as="geometry" /></mxCell><mxCell id="sep" value="&lt;b&gt;&lt;font color=&quot;#b85450&quot; style=&quot;font-size: 15px;&quot;&gt;Separated kernels&lt;/font&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontSize=13;align=left;" vertex="1" parent="1"><mxGeometry x="55" y="72" width="190" height="24" as="geometry" /></mxCell><mxCell id="same" value="&lt;font color=&quot;#57606a&quot;&gt;same MoE math, exposed runtime boundaries&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontSize=13;align=right;" vertex="1" parent="1"><mxGeometry x="720" y="72" width="225" height="24" as="geometry" /></mxCell><mxCell id="dispatch" value="&lt;b&gt;Dispatch&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 13px;&quot;&gt;X&lt;sub&gt;g&lt;/sub&gt;, s&lt;sub&gt;g&lt;/sub&gt;&lt;br&gt;&amp;larr; dispatch(X, &amp;pi;, s)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="45" y="112" width="170" height="92" as="geometry" /></mxCell><mxCell id="linear1" value="&lt;b&gt;Linear1&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 13px;&quot;&gt;H&lt;sub&gt;g&lt;/sub&gt; = X&lt;sub&gt;g&lt;/sub&gt; W&lt;sub&gt;1,e&lt;/sub&gt;&lt;sup&gt;T&lt;/sup&gt;&lt;br&gt;H&lt;sub&gt;g&lt;/sub&gt; = [G&lt;sub&gt;g&lt;/sub&gt;, U&lt;sub&gt;g&lt;/sub&gt;]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="235" y="112" width="170" height="92" as="geometry" /></mxCell><mxCell id="swiglu" value="&lt;b&gt;SwiGLU + s&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 13px;&quot;&gt;A&lt;sub&gt;g&lt;/sub&gt; = SiLU(G&lt;sub&gt;g&lt;/sub&gt;) &amp;odot; U&lt;sub&gt;g&lt;/sub&gt;&lt;br&gt;A&lt;sub&gt;g&lt;/sub&gt; &amp;larr; A&lt;sub&gt;g&lt;/sub&gt; &amp;middot; s&lt;sub&gt;g&lt;/sub&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="425" y="112" width="170" height="92" as="geometry" /></mxCell><mxCell id="linear2" value="&lt;b&gt;Linear2&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 13px;&quot;&gt;Z&lt;sub&gt;t,k&lt;/sub&gt; = A&amp;#770;&lt;sub&gt;g&lt;/sub&gt; W&lt;sub&gt;2,e&lt;/sub&gt;&lt;sup&gt;T&lt;/sup&gt;&lt;br&gt;BF16 slot&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="615" y="112" width="170" height="92" as="geometry" /></mxCell><mxCell id="combine" value="&lt;b&gt;Combine&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 13px;&quot;&gt;Y = Combine(Z, handle)&lt;br&gt;Y&lt;sub&gt;t&lt;/sub&gt; = &amp;Sigma;&lt;sub&gt;k&lt;/sub&gt; Z&lt;sub&gt;t,k&lt;/sub&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="805" y="112" width="170" height="92" as="geometry" /></mxCell><mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#24292f;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="dispatch" target="linear1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#24292f;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="linear1" target="swiglu"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#24292f;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="swiglu" target="linear2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#24292f;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="linear2" target="combine"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="materialize" value="&lt;b&gt;&lt;font color=&quot;#b85450&quot;&gt;HBM / runtime materializes X&lt;sub&gt;g&lt;/sub&gt;, H&lt;sub&gt;g&lt;/sub&gt;, A&lt;sub&gt;g&lt;/sub&gt;, Z&lt;sub&gt;t,k&lt;/sub&gt; and combine slots&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#57606a&quot;&gt;top-k weight s is already folded before Linear2; Combine only gathers and sums slots&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f0;strokeColor=#b85450;strokeWidth=1.6;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="235" y="252" width="530" height="52" as="geometry" /></mxCell><mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="swiglu" target="materialize"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="mega_label" value="&lt;b&gt;&lt;font color=&quot;#5fa55f&quot; style=&quot;font-size: 15px;&quot;&gt;Mega MoE&lt;/font&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontSize=13;align=left;" vertex="1" parent="1"><mxGeometry x="55" y="332" width="130" height="24" as="geometry" /></mxCell><mxCell id="mega" value="&lt;b&gt;&lt;font color=&quot;#5fa55f&quot; style=&quot;font-size: 16px;&quot;&gt;persistent kernel over expert waves&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;D(X,&amp;pi;,s) &amp;parallel; L1(W&lt;sub&gt;1&lt;/sub&gt;) &amp;parallel; SiLU*s+Q &amp;parallel; L2(W&lt;sub&gt;2&lt;/sub&gt;) &amp;parallel; Combine(slot&lt;sub&gt;k&lt;/sub&gt;)&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4faf4;strokeColor=#5fa55f;strokeWidth=2;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="155" y="358" width="690" height="76" as="geometry" /></mxCell><mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#5fa55f;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="materialize" target="mega"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="foot" value="&lt;font color=&quot;#57606a&quot;&gt;Semantics stay fixed; lifetimes shrink from global tensors to SMEM / TMEM / registers.&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1"><mxGeometry x="185" y="452" width="630" height="28" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>